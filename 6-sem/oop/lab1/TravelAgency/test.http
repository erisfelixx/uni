### спроба створити тур БЕЗ токена (має бути помилка 401)
POST http://localhost:8080/TravelAgency/api/tours
Content-Type: application/json

{
  "title": "Вікенд у Парижі",
  "description": "Романтична подорож на 3 дні",
  "tourType": "EXCURSION",
  "basePrice": 350.00,
  "isHot": true
}

